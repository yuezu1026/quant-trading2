# Quant Trading — 环境变量配置
# 复制此文件为 .env 并修改

# 数据库 (开发默认 SQLite)
DATABASE_URL=sqlite:///quant.db
# DATABASE_URL=postgresql://quant:quant@localhost:5432/quant

# Redis (可选，模拟/实盘使用)
REDIS_URL=redis://localhost:6379/0

# 日志
LOG_LEVEL=INFO
LOG_FILE=./logs/quant.log

# 回测默认参数
INITIAL_CASH=100000.0

# 实盘 — QMT 配置
QMT_MINI=true
QMT_PATH=

# 告警
DINGTALK_WEBHOOK=
DINGTALK_SECRET=
WECHAT_WEBHOOK=
